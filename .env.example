# ──────────────────────────────────────────
#  Server
# ──────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ──────────────────────────────────────────
#  PostgreSQL  (Railway auto-fills DATABASE_URL)
# ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ──────────────────────────────────────────
#  JWT
# ──────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ──────────────────────────────────────────
#  Email (OTP delivery)
#  Use any SMTP: Yandex, Mail.ru, Resend, SendGrid…
# ──────────────────────────────────────────
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.ru
SMTP_PASS=your_smtp_password
EMAIL_FROM="UEFN с нуля <noreply@yourdomain.ru>"

# ──────────────────────────────────────────
#  Frontend URL (for CORS)
# ──────────────────────────────────────────
FRONTEND_URL=https://yourdomain.ru

# ──────────────────────────────────────────
#  OTP
# ──────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
